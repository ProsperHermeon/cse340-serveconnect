<%- include('partials/header', { title: title }) %>

<section class="hero">
  <p class="eyebrow">Local service, made simple</p>
  <h1 class="hero-title">Find your next way to help.</h1>
  <p class="hero-lead">
    ServeConnect brings volunteers, service organizations, and hands-on projects
    into one place, so an afternoon of your time lands exactly where it is needed.
  </p>
  <div class="hero-actions">
    <a class="btn btn-primary" href="/projects">Browse projects</a>
    <a class="btn btn-ghost" href="/organizations">Meet the organizations</a>
  </div>
</section>

<section class="how">
  <h2 class="section-title">How it works</h2>
  <ol class="how-steps">
    <li>
      <h3>Pick a category</h3>
      <p>Start from what you care about, from trail work to tutoring.</p>
    </li>
    <li>
      <h3>Choose a project</h3>
      <p>Every project lists its sponsoring organization, date, and location.</p>
    </li>
    <li>
      <h3>Show up and serve</h3>
      <p>Bring yourself. The organization handles the rest.</p>
    </li>
  </ol>
</section>

